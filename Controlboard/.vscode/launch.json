{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Controlboard",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceFolder}/build/Debug/Controlboard.elf",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f0x.cfg"
            ],
            "openOCDLaunchCommands": [
                "set FLASH_SIZE 0x20000"
            ],
            "runToEntryPoint": "main"
        }
    ]
}
